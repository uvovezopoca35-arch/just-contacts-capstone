# --- ADK agent environment ---
# Copy to adk-agent/.env

# Use Google AI Studio (not Vertex AI) so a plain Gemini API key is enough.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# Passed through to the MCP server the agents spawn over stdio.
# The single Firebase user whose contacts the agent may access (see mcp-server/README.md).
MCP_USER_ID=

# Needed by the MCP server child process (Firestore access). Single-line JSON.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# If omitted here, the MCP server reads it from the repo-root .env instead.
