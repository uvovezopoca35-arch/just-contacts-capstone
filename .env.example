# --- Just Contacts: environment variables ---
# Copy to .env (local dev) and set the same values in Vercel → Project Settings → Environment Variables.

# Firebase web (client) config. Public-by-design values (a Firebase web apiKey
# identifies the project; security is enforced by Firestore Rules + App Check),
# but loaded from env so no keys live in the code. Firebase Console → Project
# settings → Your apps → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Gemini API key (AI parsing, search, summaries, embeddings) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Override the default LLM (optional). Default: googleai/gemini-2.5-flash-lite
# GEMINI_MODEL=googleai/gemini-2.0-flash

# Groq API key (optional) — when set, voice messages are transcribed with
# Whisper large-v3-turbo on Groq (cheaper/faster than Gemini for audio).
# https://console.groq.com/keys
# GROQ_API_KEY=

# Telegram bot token from @BotFather (bot webhook + WebApp auth)
TELEGRAM_BOT_TOKEN=

# Random shared secret protecting the bot webhook. Generate e.g.:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# After changing it, re-register the webhook: GET /api/bot/webhook?secret=<value>
TELEGRAM_WEBHOOK_SECRET=

# Public base URL of the deployment (used when registering the Telegram webhook)
# PUBLIC_BASE_URL=https://your-app.vercel.app

# Firebase Admin service account JSON (single line) — required in production for
# Telegram auth (custom tokens). Firebase Console → Project Settings → Service accounts.
# Also required by the MCP server (it uses Admin credentials, scoped to one user).
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# --- MCP server (mcp-server/server.ts) ---
# The single Firebase user id the MCP server is allowed to read/write. This is
# the hard security scope: tools never accept a user id from the model, so the
# agent can only ever touch THIS user's contacts. For a contact saved via the
# Telegram bot the id looks like "tg_<telegramUserId>"; for a web/Firebase-Auth
# user it is the Firebase UID. REQUIRED — the server refuses to start without it.
MCP_USER_ID=
