rules_version = '2';

/**
 * FIREBASE STORAGE SECURITY RULES
 * 
 * Users can only read/write their own avatar files.
 * Path structure: /users/{userId}/avatars/{fileName}
 */
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only access their own avatar files
    match /users/{userId}/avatars/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // max 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
